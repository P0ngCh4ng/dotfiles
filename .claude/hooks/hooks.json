{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/scripts/check-project-docs.js\""
          }
        ],
        "description": "Check for project architecture and database documentation"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/scripts/track-doc-updates.js\""
          }
        ],
        "description": "Track file modifications and suggest documentation updates"
      }
    ]
  }
}
