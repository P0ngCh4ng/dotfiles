#!/bin/bash
# pre-commit
# Git pre-commit hook for Next.js 14 App Router projects
# Validates directory structure, Client Components, API formats, TypeScript, and tests

set -e

# Color codes for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Track validation status
VALIDATION_FAILED=false
WARNINGS_FOUND=false

# Function to print colored output
print_header() {
    echo -e "\n${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${CYAN}$1${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

print_error() {
    echo -e "${RED}✗ $1${NC}"
    VALIDATION_FAILED=true
}

print_warning() {
    echo -e "${YELLOW}⚠ $1${NC}"
    WARNINGS_FOUND=true
}

print_success() {
    echo -e "${GREEN}✓ $1${NC}"
}

print_info() {
    echo -e "${CYAN}ℹ $1${NC}"
}

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    print_info "No files staged for commit"
    exit 0
fi

# Filter for relevant file types
TS_FILES=$(echo "$STAGED_FILES" | grep -E '\.(ts|tsx)$' || true)
API_FILES=$(echo "$STAGED_FILES" | grep -E 'app/api/.*/route\.ts$' || true)
COMPONENT_FILES=$(echo "$STAGED_FILES" | grep -E '\.(tsx)$' || true)

print_header "🔍 Pre-Commit Validation Starting"

# ============================================================================
# 1. DIRECTORY STRUCTURE VALIDATION
# ============================================================================
print_header "1. Directory Structure Validation"

STRUCTURE_VALID=true

# Check for common mistakes
for file in $STAGED_FILES; do
    # API routes should be in app/api/ and named route.ts
    if [[ "$file" =~ app/api/ ]] && [[ ! "$file" =~ route\.ts$ ]] && [[ "$file" =~ \.(ts|tsx)$ ]]; then
        print_error "API file should be named 'route.ts': $file"
        STRUCTURE_VALID=false
    fi

    # Pages should be named page.tsx
    if [[ "$file" =~ app/.*/.*\.tsx$ ]] && [[ ! "$file" =~ (page|layout|loading|error|not-found|template)\.tsx$ ]] && [[ ! "$file" =~ app/components/ ]]; then
        if [[ ! "$file" =~ /\[.*\]/ ]]; then  # Allow dynamic routes
            print_warning "Possible misnamed page file (should be page.tsx, layout.tsx, etc.): $file"
        fi
    fi

    # Components should be in components directory
    if [[ "$file" =~ \.(tsx)$ ]] && [[ ! "$file" =~ (app/components/|app/.*/(page|layout|loading|error|not-found|template)\.tsx) ]]; then
        print_warning "Component file outside components directory: $file"
    fi

    # Check for files in incorrect locations
    if [[ "$file" =~ app/.*\.(css|scss|sass)$ ]] && [[ ! "$file" =~ app/globals\.css$ ]]; then
        print_warning "CSS file in app directory (consider using CSS modules or Tailwind): $file"
    fi
done

if [ "$STRUCTURE_VALID" = true ] && [ "$WARNINGS_FOUND" = false ]; then
    print_success "Directory structure is valid"
fi

# ============================================================================
# 2. CLIENT COMPONENT VALIDATION
# ============================================================================
print_header "2. Client Component Validation"

CLIENT_COMPONENT_ISSUES=false

for file in $COMPONENT_FILES; do
    if [ -f "$file" ]; then
        HAS_USE_CLIENT=$(grep -l "^['\"]use client['\"]" "$file" || true)

        if [ -n "$HAS_USE_CLIENT" ]; then
            # File has 'use client' directive, verify it's needed

            # Check for hooks that require client components
            HAS_HOOKS=$(grep -E '(useState|useEffect|useContext|useReducer|useCallback|useMemo|useRef|useLayoutEffect)' "$file" || true)
            HAS_EVENT_HANDLERS=$(grep -E '(onClick|onChange|onSubmit|onFocus|onBlur|onKeyDown|onKeyUp|onMouseEnter|onMouseLeave)' "$file" || true)
            HAS_BROWSER_APIS=$(grep -E '(window\.|document\.|localStorage|sessionStorage|navigator\.)' "$file" || true)

            if [ -z "$HAS_HOOKS" ] && [ -z "$HAS_EVENT_HANDLERS" ] && [ -z "$HAS_BROWSER_APIS" ]; then
                print_warning "'use client' may be unnecessary in: $file"
                print_info "  Consider removing if no client-side features are used"
                CLIENT_COMPONENT_ISSUES=true
            fi
        else
            # No 'use client' directive, check if it should have one
            HAS_HOOKS=$(grep -E '(useState|useEffect|useContext|useReducer|useCallback|useMemo|useRef|useLayoutEffect)' "$file" || true)
            HAS_EVENT_HANDLERS=$(grep -E '(onClick|onChange|onSubmit|onFocus|onBlur|onKeyDown|onKeyUp|onMouseEnter|onMouseLeave)=' "$file" || true)

            if [ -n "$HAS_HOOKS" ] || [ -n "$HAS_EVENT_HANDLERS" ]; then
                print_error "Missing 'use client' directive in: $file"
                print_info "  File uses client-side features but is not marked as client component"
                CLIENT_COMPONENT_ISSUES=true
            fi
        fi
    fi
done

if [ "$CLIENT_COMPONENT_ISSUES" = false ]; then
    print_success "Client component directives are correct"
fi

# ============================================================================
# 3. API RESPONSE FORMAT VALIDATION
# ============================================================================
print_header "3. API Response Format Validation"

API_FORMAT_ISSUES=false

for file in $API_FILES; do
    if [ -f "$file" ]; then
        # Check for NextResponse usage
        HAS_NEXT_RESPONSE=$(grep -c "NextResponse" "$file" || true)

        if [ "$HAS_NEXT_RESPONSE" -eq 0 ]; then
            print_error "API route should use NextResponse: $file"
            API_FORMAT_ISSUES=true
        fi

        # Check for consistent response format
        HAS_SUCCESS_FORMAT=$(grep -E "success:\s*(true|false)" "$file" || true)

        if [ -z "$HAS_SUCCESS_FORMAT" ]; then
            print_warning "API route may not follow standard response format: $file"
            print_info "  Expected format: { success: true/false, data/error: ... }"
            API_FORMAT_ISSUES=true
        fi

        # Check for error handling
        HAS_TRY_CATCH=$(grep -c "try\s*{" "$file" || true)

        if [ "$HAS_TRY_CATCH" -eq 0 ]; then
            print_warning "API route missing try-catch error handling: $file"
            API_FORMAT_ISSUES=true
        fi

        # Check for named exports (GET, POST, etc.)
        HAS_NAMED_EXPORT=$(grep -E "^export\s+(async\s+)?function\s+(GET|POST|PUT|DELETE|PATCH)" "$file" || true)

        if [ -z "$HAS_NAMED_EXPORT" ]; then
            print_error "API route missing named export (GET, POST, etc.): $file"
            API_FORMAT_ISSUES=true
        fi
    fi
done

if [ "$API_FORMAT_ISSUES" = false ] && [ -n "$API_FILES" ]; then
    print_success "API response formats are valid"
elif [ -z "$API_FILES" ]; then
    print_info "No API routes to validate"
fi

# ============================================================================
# 4. TYPESCRIPT TYPE CHECK
# ============================================================================
print_header "4. TypeScript Type Check"

if [ -n "$TS_FILES" ]; then
    print_info "Running TypeScript type check..."

    if npm run type-check --silent 2>&1; then
        print_success "TypeScript type check passed"
    else
        print_error "TypeScript type check failed"
        print_info "Run 'npm run type-check' to see detailed errors"
        VALIDATION_FAILED=true
    fi
else
    print_info "No TypeScript files to check"
fi

# ============================================================================
# 5. LINTING CHECK
# ============================================================================
print_header "5. Linting Check"

if [ -n "$TS_FILES" ]; then
    print_info "Running ESLint..."

    if npm run lint --silent 2>&1; then
        print_success "ESLint check passed"
    else
        print_error "ESLint check failed"
        print_info "Run 'npm run lint' to see detailed errors"
        VALIDATION_FAILED=true
    fi
else
    print_info "No files to lint"
fi

# ============================================================================
# 6. TEST EXECUTION
# ============================================================================
print_header "6. Running Tests"

# Check if there are test files
TEST_FILES=$(echo "$STAGED_FILES" | grep -E '\.(test|spec)\.(ts|tsx)$' || true)

if command -v npm &> /dev/null; then
    print_info "Running test suite..."

    if npm test -- --passWithNoTests --silent 2>&1; then
        print_success "All tests passed"
    else
        print_error "Tests failed"
        print_info "Run 'npm test' to see detailed errors"
        VALIDATION_FAILED=true
    fi
else
    print_warning "npm not found, skipping tests"
fi

# ============================================================================
# 7. BUILD CHECK (OPTIONAL - can be commented out for faster commits)
# ============================================================================
# Uncomment to enable build check before commit
# print_header "7. Build Check"
#
# if [ -n "$TS_FILES" ]; then
#     print_info "Running production build check..."
#
#     if npm run build 2>&1 | tail -n 20; then
#         print_success "Build check passed"
#     else
#         print_error "Build check failed"
#         VALIDATION_FAILED=true
#     fi
# fi

# ============================================================================
# SUMMARY AND FINAL DECISION
# ============================================================================
print_header "📊 Validation Summary"

if [ "$VALIDATION_FAILED" = true ]; then
    echo -e "${RED}"
    echo "╔════════════════════════════════════════════════════════════════╗"
    echo "║                    ❌ COMMIT BLOCKED ❌                        ║"
    echo "╚════════════════════════════════════════════════════════════════╝"
    echo -e "${NC}"
    echo "Please fix the errors above before committing."
    echo ""
    echo "Common fixes:"
    echo "  • TypeScript errors: Run 'npm run type-check' and fix reported issues"
    echo "  • Linting errors: Run 'npm run lint -- --fix' to auto-fix some issues"
    echo "  • Test failures: Run 'npm test' and fix failing tests"
    echo "  • API format: Ensure using NextResponse and standard response format"
    echo "  • Client components: Add 'use client' directive if using hooks/events"
    echo ""
    echo "To skip this hook (NOT RECOMMENDED):"
    echo "  git commit --no-verify"
    echo ""
    exit 1
fi

if [ "$WARNINGS_FOUND" = true ]; then
    echo -e "${YELLOW}"
    echo "╔════════════════════════════════════════════════════════════════╗"
    echo "║              ⚠️  WARNINGS FOUND - REVIEW ABOVE ⚠️              ║"
    echo "╚════════════════════════════════════════════════════════════════╝"
    echo -e "${NC}"
    echo "Warnings detected but commit is allowed."
    echo "Please review the warnings and consider fixing them."
    echo ""
fi

echo -e "${GREEN}"
echo "╔════════════════════════════════════════════════════════════════╗"
echo "║                  ✓ VALIDATION PASSED ✓                        ║"
echo "╚════════════════════════════════════════════════════════════════╝"
echo -e "${NC}"
echo "All checks passed. Proceeding with commit..."
echo ""

exit 0
